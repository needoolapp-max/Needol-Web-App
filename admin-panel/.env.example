# Admin panel environment template.
# Vite exposes VITE_* values to browser users. Do not place true server secrets here.

VITE_API_BASE_URL=http://localhost:4100
VITE_PUBLIC_SITE_URL=http://localhost:3000

# Optional demo-only token matching backend ADMIN_API_TOKEN.
# This is not production-grade auth because browser bundles are inspectable.
VITE_ADMIN_API_TOKEN=

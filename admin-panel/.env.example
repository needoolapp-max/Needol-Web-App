# Admin panel environment template.
# Vite exposes VITE_* values to browser users. Do not place true server secrets here.

VITE_API_BASE_URL=http://localhost:4100
VITE_PUBLIC_SITE_URL=http://localhost:3000

# Clerk publishable key is safe to expose. Get it from Clerk Dashboard > API keys.
VITE_CLERK_PUBLISHABLE_KEY=

# Optional UI-side guard only. Real protection is enforced by backend ADMIN_ALLOWED_EMAILS.
# Put the same single Gmail here for a cleaner "access denied" screen.
VITE_ADMIN_ALLOWED_EMAILS=your-admin@gmail.com

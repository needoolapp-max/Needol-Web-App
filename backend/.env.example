# Backend local/deployment environment template.
# Copy to backend/.env for local testing only. Never commit real .env files.

NODE_ENV=development
PORT=4100

# Comma-separated origins allowed to call the API.
# For deployment, replace these with your real frontend/admin URLs.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3200,http://127.0.0.1:3200

# local = backend/data/store.json
# supabase = one-row Supabase JSON state store for founder/demo deployments
DATA_PROVIDER=local

# Required only when DATA_PROVIDER=supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STATE_TABLE=needool_app_state
SUPABASE_STATE_KEY=dummy_store

# Optional. If set, /api/admin/* endpoints require x-admin-token.
# For a browser admin panel this is only lightweight demo protection because Vite exposes VITE_* values.
# Use Cloudflare Access/Vercel protection for real admin protection.
ADMIN_API_TOKEN=

# Optional email hook. Leave blank while email is still dummy.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Needool <hello@needool.local>

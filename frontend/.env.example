# Public frontend environment template.
# Vite exposes VITE_* values to browser users. Do not place server secrets here.

VITE_API_BASE_URL=http://localhost:4100
VITE_ADMIN_PANEL_URL=http://localhost:3200

# Frontend Clerk publishable key — from your FRONTEND Clerk application (not the admin app).
# Create a second Clerk application at https://dashboard.clerk.com for frontend users.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

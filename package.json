{
  "name": "needool-web-app",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "admin-panel"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend dev:admin",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "dev:admin": "npm --workspace admin-panel run dev",
    "build": "npm --workspace frontend run build && npm --workspace admin-panel run build",
    "preview:frontend": "npm --workspace frontend run preview",
    "preview:admin": "npm --workspace admin-panel run preview",
    "test": "npm --prefix backend test && npm --workspace frontend run test && npm run test:e2e",
    "test:backend": "npm --prefix backend test",
    "test:frontend": "npm --workspace frontend run test",
    "test:e2e": "playwright test",
    "test:lighthouse": "node tests/lighthouse-smoke.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^12.8.2",
    "npm-run-all": "^4.1.5"
  }
}
